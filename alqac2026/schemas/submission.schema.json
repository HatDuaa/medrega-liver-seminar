{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ALQAC 2026 submission",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["case_id", "prediction", "case_evidence", "law_evidence"],
    "properties": {
      "case_id": {"type": "string", "minLength": 1},
      "prediction": {
        "enum": ["A_WIN", "B_WIN", "PARTIAL_A_WIN", "PARTIAL_B_WIN"]
      },
      "case_evidence": {
        "type": "array",
        "uniqueItems": true,
        "items": {"type": "string", "minLength": 1}
      },
      "law_evidence": {
        "type": "array",
        "uniqueItems": true,
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["law_id", "aid"],
          "properties": {
            "law_id": {"type": "string", "minLength": 1},
            "aid": {"type": "integer"}
          }
        }
      }
    }
  }
}
